<!-- Hero Section -->
<section id="hero" class="relative min-h-screen flex flex-col items-center justify-center pt-24 pb-24 overflow-hidden">
  <!-- Background image -->
  <div class="absolute inset-0 z-0">
    <img src="/images/heroviewbg.png" alt="" class="hero-bg-img w-full h-full object-cover" />
    <!-- Dark overlay for text readability -->
    <div class="absolute inset-0 bg-background-dark/70"></div>
    <!-- Bottom gradient fade into next section -->
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-background-dark"></div>
    <!-- Top gradient for navbar area -->
    <div class="absolute inset-0 bg-gradient-to-b from-background-dark/50 via-transparent to-transparent" style="height: 30%;"></div>
  </div>
  <div class="absolute inset-0 noise-overlay pointer-events-none z-[1]"></div>
  <!-- Floating ambient orbs -->
  <div class="parallax-slow absolute top-20 left-10 w-72 h-72 bg-primary/10 rounded-full blur-[100px] pointer-events-none z-[2]"></div>
  <div class="parallax-fast absolute bottom-20 right-10 w-96 h-96 bg-accent/8 rounded-full blur-[120px] pointer-events-none z-[2]"></div>

  <div class="relative z-10 container mx-auto px-4 flex flex-col items-center text-center max-w-4xl">
    <!-- Massive Typography — each line animates separately -->
    <h1 class="font-display font-bold text-4xl sm:text-5xl md:text-6xl lg:text-[96px] leading-[1.05] mb-4 sm:mb-6 text-text-light drop-shadow-lg gsap-hero-badge">
      <span class="gsap-hero-text block">Hook Up With Our</span>
      <span class="gsap-hero-text block text-primary/90 italic">Hospitality</span>
    </h1>
    <!-- Tags pill -->
    <div class="gsap-hero-text inline-flex items-center gap-3 sm:gap-6 px-4 sm:px-8 py-2 sm:py-3 rounded-full glass-nav border border-white/10 mb-6 sm:mb-8 flex-wrap justify-center">
      <span class="text-primary-hover font-medium tracking-[0.15em] sm:tracking-[0.2em] uppercase text-[10px] sm:text-xs">Events</span>
      <span class="size-1 rounded-full bg-primary/40 hidden sm:block"></span>
      <span class="text-primary-hover font-medium tracking-[0.15em] sm:tracking-[0.2em] uppercase text-[10px] sm:text-xs">Live Music</span>
      <span class="size-1 rounded-full bg-primary/40 hidden sm:block"></span>
      <span class="text-primary-hover font-medium tracking-[0.15em] sm:tracking-[0.2em] uppercase text-[10px] sm:text-xs">Celebration</span>
      <span class="size-1 rounded-full bg-primary/40 hidden sm:block"></span>
      <span class="text-primary-hover font-medium tracking-[0.15em] sm:tracking-[0.2em] uppercase text-[10px] sm:text-xs">Drinks</span>
