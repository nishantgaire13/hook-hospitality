<!-- Booking CTA Section -->
<section id="booking-cta" class="relative bg-gradient-to-r from-primary to-accent py-24 px-6 sm:px-12 lg:px-24 flex flex-col items-center justify-center text-center overflow-hidden">
  <div class="gsap-scale-in relative z-10 w-full max-w-5xl mx-auto">
    <h2 class="font-display font-bold text-3xl sm:text-5xl md:text-[64px] text-text-dark leading-tight mb-8 sm:mb-12">Ready to be Hooked?</h2>
    <form action="/booking" method="GET" class="gsap-fade-up hover-lift bg-background-light p-4 rounded-md shadow-warm-dark flex flex-col md:flex-row items-center gap-4 max-w-4xl mx-auto w-full">
      <div class="flex-1 w-full flex items-center border-b md:border-b-0 md:border-r border-muted/30 pb-4 md:pb-0 md:pr-4">
        <span class="material-symbols-outlined text-muted mr-3">calendar_today</span>
        <div class="flex flex-col items-start w-full">
          <label class="text-xs sm:text-[11px] uppercase tracking-wider sm:tracking-widest text-muted font-medium mb-1">Date</label>
          <input class="w-full bg-transparent border-none p-0 text-text-dark font-medium focus:ring-0 text-sm" type="date" name="date" />
        </div>
      </div>
      <div class="flex-1 w-full flex items-center border-b md:border-b-0 md:border-r border-muted/30 pb-4 md:pb-0 md:px-4">
        <span class="material-symbols-outlined text-muted mr-3">schedule</span>
        <div class="flex flex-col items-start w-full">
          <label class="text-xs sm:text-[11px] uppercase tracking-wider sm:tracking-widest text-muted font-medium mb-1">Time</label>
          <input type="time" name="time" class="w-full bg-transparent border-none p-0 text-text-dark font-medium focus:ring-0 text-sm" />
        </div>
      </div>
      <div class="flex-1 w-full flex items-center pb-4 md:pb-0 md:px-4">
        <span class="material-symbols-outlined text-muted mr-3">group</span>
        <div class="flex flex-col items-start w-full">
          <label class="text-xs sm:text-[11px] uppercase tracking-wider sm:tracking-widest text-muted font-medium mb-1">Guests</label>
          <select name="guests" class="w-full bg-transparent border-none p-0 text-text-dark font-medium focus:ring-0 text-sm cursor-pointer">
            <option>1 Person</option><option>2 People</option><option>3 People</option><option>4 People</option><option>5 People</option><option>6 People</option><option>7 People</option><option>8 People</option><option>9 People</option><option>10+ People</option>
          </select>
        </div>
      </div>
      <button type="submit" class="btn-hover w-full md:w-auto mt-4 md:mt-0 bg-primary hover:bg-primary-hover transition-colors text-text-dark font-semibold text-[15px] px-8 py-4 rounded-sm whitespace-nowrap flex items-center justify-center gap-2">
        Find Table <span class="material-symbols-outlined text-lg">arrow_forward</span>
      </button>
    </form>
  </div>
</section>

