<%- include('partials/head') %>
<%- include('partials/navbar') %>

<!-- Contact Hero -->
<section class="relative pt-32 pb-16 hero-gradient">
  <div class="absolute inset-0 noise-overlay pointer-events-none"></div>
  <div class="relative z-10 container mx-auto px-4 text-center max-w-4xl">
    <h1 class="font-display font-bold text-3xl sm:text-5xl md:text-6xl lg:text-[80px] leading-[1.1] mb-4 sm:mb-6 text-text-light">Get In Touch</h1>
    <p class="text-muted/90 text-sm sm:text-lg max-w-2xl mx-auto font-newsreader italic px-2">We'd love to hear from you. Visit us, call us, or drop a message anytime.</p>
  </div>
</section>

<!-- Map + Contact Details -->
<section class="bg-background-dark py-12 sm:py-24 px-4 sm:px-6 lg:px-8">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12">

      <!-- Google Map -->
      <div class="rounded-xl overflow-hidden border border-muted/20 h-[300px] sm:h-[400px] lg:h-full min-h-[350px]">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3533.0!2d85.3419!3d27.6785!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x39eb19f31b62b5e1%3A0x5a0e42e5b5c5d7a6!2sHook%20Hospitality!5e0!3m2!1sen!2snp!4v1700000000000"
          width="100%" height="100%" style="border:0; filter: invert(0.9) hue-rotate(180deg) brightness(0.8) contrast(1.2);" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade">
        </iframe>
      </div>

      <!-- Contact Info Cards -->
      <div class="flex flex-col gap-6">

        <!-- Address -->
        <div class="bg-surface-dark border border-muted/20 rounded-xl p-6 sm:p-8 flex items-start gap-5 group hover:border-primary/30 transition-colors">
          <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center flex-shrink-0 group-hover:bg-primary/20 transition-colors">
            <span class="material-symbols-outlined text-primary text-2xl" style="font-variation-settings: 'FILL' 1;">location_on</span>
          </div>
          <div>
            <h3 class="text-text-light font-display text-lg font-bold mb-2">Our Location</h3>
            <p class="text-muted text-sm leading-relaxed">Hook Hospitality, Shrinkhala Galli,<br/>Sahayoginagar, Koteshwor,<br/>Kathmandu 44600, Nepal</p>
            <a href="https://maps.google.com/?q=Hook+Hospitality+Kathmandu" target="_blank" class="inline-flex items-center gap-1.5 text-primary text-sm font-medium mt-3 hover:text-primary-hover transition-colors">
              Open in Maps
              <span class="material-symbols-outlined text-sm">arrow_outward</span>
            </a>
          </div>
        </div>

        <!-- Phone -->
        <div class="bg-surface-dark border border-muted/20 rounded-xl p-6 sm:p-8 flex items-start gap-5 group hover:border-primary/30 transition-colors">
          <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center flex-shrink-0 group-hover:bg-primary/20 transition-colors">
            <span class="material-symbols-outlined text-primary text-2xl" style="font-variation-settings: 'FILL' 1;">call</span>
          </div>
          <div>
            <h3 class="text-text-light font-display text-lg font-bold mb-2">Phone</h3>
            <a class="text-muted text-sm hover:text-primary transition-colors block" href="tel:+9779851349480">+977 985-1349480</a>
            <p class="text-muted/60 text-xs mt-2">Available during opening hours</p>
          </div>
        </div>

        <!-- Email -->
        <div class="bg-surface-dark border border-muted/20 rounded-xl p-6 sm:p-8 flex items-start gap-5 group hover:border-primary/30 transition-colors">
          <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center flex-shrink-0 group-hover:bg-primary/20 transition-colors">
            <span class="material-symbols-outlined text-primary text-2xl" style="font-variation-settings: 'FILL' 1;">mail</span>
          </div>
          <div>
            <h3 class="text-text-light font-display text-lg font-bold mb-2">Email</h3>
            <a class="text-muted text-sm hover:text-primary transition-colors block" href="mailto:hookhospitalitygroup@gmail.com">hookhospitalitygroup@gmail.com</a>
            <p class="text-muted/60 text-xs mt-2">We'll get back to you within 24 hours</p>
          </div>
        </div>

        <!-- Social Media -->
        <div class="bg-surface-dark border border-muted/20 rounded-xl p-6 sm:p-8 flex items-start gap-5 group hover:border-primary/30 transition-colors">
          <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center flex-shrink-0 group-hover:bg-primary/20 transition-colors">
            <span class="material-symbols-outlined text-primary text-2xl" style="font-variation-settings: 'FILL' 1;">share</span>
          </div>
          <div>
            <h3 class="text-text-light font-display text-lg font-bold mb-3">Follow Us</h3>
            <div class="flex items-center gap-3">
              <a aria-label="Instagram" class="w-11 h-11 rounded-full border border-muted/40 flex items-center justify-center text-muted hover:text-primary hover:border-primary transition-colors" href="#">
                <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
              </a>
              <a aria-label="Facebook" class="w-11 h-11 rounded-full border border-muted/40 flex items-center justify-center text-muted hover:text-primary hover:border-primary transition-colors" href="#">
                <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M22.675 0h-21.35c-.732 0-1.325.593-1.325 1.325v21.351c0 .731.593 1.324 1.325 1.324h11.495v-9.294h-3.128v-3.622h3.128v-2.671c0-3.1 1.893-4.788 4.659-4.788 1.325 0 2.463.099 2.795.143v3.24l-1.918.001c-1.504 0-1.795.715-1.795 1.763v2.313h3.587l-.467 3.622h-3.12v9.293h6.116c.73 0 1.323-.593 1.323-1.325v-21.35c0-.732-.593-1.325-1.325-1.325z"/></svg>
              </a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<!-- CTA to Book -->
<section class="bg-gradient-to-r from-primary to-accent py-16 px-6 text-center">
  <h2 class="font-display font-bold text-3xl md:text-4xl text-text-dark mb-4">Ready to Visit?</h2>
  <p class="text-text-dark/70 mb-8 max-w-md mx-auto">Reserve your table and experience the warmth of Hook Hospitality.</p>
  <a href="/booking" class="btn-hover inline-block bg-background-dark text-text-light font-semibold px-8 py-4 rounded-full transition-colors hover:bg-surface-dark">
    Book a Table <span class="material-symbols-outlined text-lg align-middle ml-1">arrow_forward</span>
  </a>
</section>

<%- include('partials/footer') %>
