<%- include('partials/head') %>
<%- include('partials/navbar') %>

<!-- Booking Page -->
<section class="relative pt-32 pb-16 hero-gradient">
  <div class="absolute inset-0 noise-overlay pointer-events-none"></div>
  <div class="relative z-10 container mx-auto px-4 text-center max-w-4xl">
    <h1 class="font-display font-bold text-5xl sm:text-6xl md:text-[80px] leading-[1.1] mb-6 text-text-light">Reserve a Table</h1>
    <p class="text-muted/90 text-lg max-w-2xl mx-auto font-newsreader italic">Reservations are highly recommended for weekend sessions. Secure your spot for an unforgettable evening.</p>
  </div>
</section>

<!-- Booking Form Section -->
<section class="relative bg-gradient-to-r from-primary to-accent py-24 px-6 sm:px-12 lg:px-24 flex flex-col items-center justify-center text-center">
  <div class="relative z-10 w-full max-w-5xl mx-auto">
    <% if (typeof success !== 'undefined' && success) { %>
      <div class="bg-green-100 border border-green-400 text-green-700 px-6 py-4 rounded-md mb-8 text-left">
        <p class="font-semibold"><%= success %></p>
      </div>
    <% } %>

    <h2 class="font-display font-bold text-5xl sm:text-[64px] text-text-dark leading-tight mb-12">Ready to be Hooked?</h2>

    <!-- Reservation Widget -->
    <form method="POST" action="/booking" class="bg-background-light p-8 md:p-12 rounded-md shadow-warm-dark max-w-4xl mx-auto w-full text-left">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <div>
          <label class="text-[11px] uppercase tracking-widest text-muted font-medium mb-2 block">Full Name</label>
          <input class="w-full h-14 px-4 rounded-sm border border-muted/30 bg-transparent text-text-dark font-medium focus:border-primary focus:ring-primary text-sm" type="text" name="name" placeholder="Your Name" required />
        </div>
        <div>
          <label class="text-[11px] uppercase tracking-widest text-muted font-medium mb-2 block">Email</label>
          <input class="w-full h-14 px-4 rounded-sm border border-muted/30 bg-transparent text-text-dark font-medium focus:border-primary focus:ring-primary text-sm" type="email" name="email" placeholder="your@email.com" required />
        </div>
        <div>
          <label class="text-[11px] uppercase tracking-widest text-muted font-medium mb-2 block">Phone</label>
          <input class="w-full h-14 px-4 rounded-sm border border-muted/30 bg-transparent text-text-dark font-medium focus:border-primary focus:ring-primary text-sm" type="tel" name="phone" placeholder="+977 98XXXXXXXX" />
        </div>
        <div>
          <label class="text-[11px] uppercase tracking-widest text-muted font-medium mb-2 block">Date</label>
          <input class="w-full h-14 px-4 rounded-sm border border-muted/30 bg-transparent text-text-dark font-medium focus:border-primary focus:ring-primary text-sm" type="date" name="date" required />
        </div>
        <div>
          <label class="text-[11px] uppercase tracking-widest text-muted font-medium mb-2 block">Time</label>
          <select name="time" class="w-full h-14 px-4 rounded-sm border border-muted/30 bg-transparent text-text-dark font-medium focus:border-primary focus:ring-primary text-sm cursor-pointer">
            <option>19:00</option>
            <option>19:30</option>
            <option>20:00</option>
            <option>20:30</option>
            <option>21:00</option>
            <option>21:30</option>
          </select>
        </div>
        <div>
          <label class="text-[11px] uppercase tracking-widest text-muted font-medium mb-2 block">Guests</label>
          <select name="guests" class="w-full h-14 px-4 rounded-sm border border-muted/30 bg-transparent text-text-dark font-medium focus:border-primary focus:ring-primary text-sm cursor-pointer">
            <option>2 People</option>
            <option>3 People</option>
            <option>4 People</option>
            <option>5+ People</option>
          </select>
        </div>
      </div>
      <div class="mb-8">
        <label class="text-[11px] uppercase tracking-widest text-muted font-medium mb-2 block">Special Requests</label>
        <textarea class="w-full h-32 px-4 py-3 rounded-sm border border-muted/30 bg-transparent text-text-dark font-medium focus:border-primary focus:ring-primary text-sm resize-none" name="notes" placeholder="Any special dietary requirements, occasion, or seating preferences..."></textarea>
      </div>
      <button type="submit" class="w-full bg-primary hover:bg-primary-hover transition-colors text-text-dark font-semibold text-lg px-8 py-4 rounded-sm flex items-center justify-center gap-2">
        Confirm Reservation <span class="material-symbols-outlined text-lg">arrow_forward</span>
      </button>
      <p class="mt-4 text-center text-xs text-muted">We respect your privacy. No spam, just hospitality.</p>
    </form>
  </div>
</section>

<!-- Contact Info -->
<section class="bg-background-dark py-20 px-6">
  <div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
    <div class="flex flex-col items-center gap-3">
      <span class="material-symbols-outlined text-primary text-4xl">location_on</span>
      <h4 class="text-text-light font-display text-xl font-bold">Visit Us</h4>
      <p class="text-muted text-sm">Shrinkhala Galli, Koteshwor<br/>Kathmandu 44600, Nepal</p>
    </div>
    <div class="flex flex-col items-center gap-3">
      <span class="material-symbols-outlined text-primary text-4xl">mail</span>
      <h4 class="text-text-light font-display text-xl font-bold">Email Us</h4>
      <a class="text-muted text-sm hover:text-primary transition-colors" href="mailto:hookhospitalitygroup@gmail.com">hookhospitalitygroup@gmail.com</a>
    </div>
    <div class="flex flex-col items-center gap-3">
      <span class="material-symbols-outlined text-primary text-4xl">call</span>
      <h4 class="text-text-light font-display text-xl font-bold">Call Us</h4>
      <a class="text-muted text-sm hover:text-primary transition-colors" href="tel:+9779851349480">+977 985-1349480</a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
